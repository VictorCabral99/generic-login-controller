<div class="w-full max-w-md bg-white rounded-2xl shadow-lg p-8">

    <!-- Título -->
    <div class="text-center mb-8">
        <h1 class="text-2xl font-bold text-gray-800">Recuperar senha</h1>
        <p class="text-gray-500 text-sm mt-2">
            Informe seu email para receber as instruções de redefinição
        </p>
    </div>

    <!-- Alerta de Erro -->
    <div id="erro" class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded-lg mb-5 hidden">
      <p id="mensagemErro"></p>
    </div>

    <!-- Alerta de Sucesso -->
    <div id="sucesso" class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded-lg mb-5 hidden">
      <p id="mensagemSucesso"></p>
    </div>

    <!-- Formulário -->
    <form id="formularioForgot" class="space-y-6">

        <!-- Email -->
        <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">
                Email
            </label>
            <input 
              id="email"
              type="email" 
              placeholder="seu@email.com"
              required
              class="w-full rounded-lg border border-gray-300 px-4 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent" 
            />
        </div>

        <!-- Botão -->
        <button 
          type="submit"
          class="w-full bg-blue-600 text-white py-2 rounded-lg font-semibold hover:bg-blue-700 transition">
            Enviar link de recuperação
        </button>

    </form>

    <!-- Voltar -->
    <div class="text-center mt-6">
        <a href="/login" class="text-sm text-blue-600 hover:underline">
            Voltar para o login
        </a>
    </div>

</div>

<script>
  document.getElementById('formularioForgot').addEventListener('submit', function(event) {
    event.preventDefault();

    const email = document.getElementById('email').value;

    fetch('/api/auth/forgot-password', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json'
      },
      body: JSON.stringify({ email })
    })
    .then(response => response.json())
    .then(data => {
      if (data.erro) {
        mostrarErro(data.erro);
        return;
      }

      if (data.mensagem) {
        mostrarSucesso('✓ Email enviado com sucesso! Verifique sua caixa de entrada e a pasta de SPAM');
        document.getElementById('formularioForgot').reset();
      }
    })
    .catch(error => {
      console.error('Erro:', error);
      mostrarErro('Erro ao enviar email. Tente novamente.');
    });
  });

  function mostrarErro(mensagem) {
    const erroDiv = document.getElementById('erro');
    const mensagemErro = document.getElementById('mensagemErro');
    mensagemErro.textContent = mensagem;
    erroDiv.classList.remove('hidden');

    setTimeout(() => {
      erroDiv.classList.add('hidden');
    }, 5000);
  }

  function mostrarSucesso(mensagem) {
    const sucessoDiv = document.getElementById('sucesso');
    const mensagemSucesso = document.getElementById('mensagemSucesso');
    mensagemSucesso.textContent = mensagem;
    sucessoDiv.classList.remove('hidden');
  }
</script>