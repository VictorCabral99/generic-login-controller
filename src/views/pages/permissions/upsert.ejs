 <div class="max-w-3xl mx-auto px-6 py-8">

    <!-- Header -->
    <div class="mb-6">
      <!-- CREATE: id = null | UPDATE: id != null -->
      <h1 class="text-2xl font-bold text-gray-800">
        Criar Permissão
        <!-- Editar Permissão -->
      </h1>
      <p class="text-sm text-gray-500 mt-1">
        Defina os dados da permissão
      </p>
    </div>

    <!-- Card -->
    <div class="bg-white rounded-lg shadow p-6">

      <form class="space-y-6">

        <!-- Key / Slug -->
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">
            Permissão (key)
          </label>
          <input
            type="text"
            placeholder="ex: user.create"
            class="w-full font-mono border border-gray-300 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500"
          />
          <p class="text-xs text-gray-500 mt-1">
            Use padrão: <code>modulo.acao</code>
          </p>
        </div>

        <!-- Nome -->
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">
            Nome
          </label>
          <input
            type="text"
            placeholder="Criar usuários"
            class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500"
          />
        </div>

        <!-- Módulo -->
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">
            Módulo
          </label>
          <select
            class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500"
          >
            <option>Selecione um módulo</option>
            <option>Usuários</option>
            <option>Permissões</option>
            <option>Relatórios</option>
            <option>Financeiro</option>
          </select>
        </div>

        <!-- Descrição -->
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">
            Descrição
          </label>
          <textarea
            rows="3"
            placeholder="Permite criar novos usuários no sistema"
            class="w-full border border-gray-300 rounded-lg px-3 py-2 resize-none focus:outline-none focus:ring-2 focus:ring-blue-500"
          ></textarea>
        </div>

        <!-- Status -->
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">
            Status
          </label>
          <select
            class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500"
          >
            <option>Ativa</option>
            <option>Inativa</option>
          </select>
        </div>

        <!-- Ações -->
        <div class="flex items-center justify-end gap-3 pt-4 border-t">
          <button
            type="button"
            class="px-4 py-2 rounded-lg border border-gray-300 text-gray-700 hover:bg-gray-100"
          >
            Cancelar
          </button>

          <!-- CREATE -->
          <button
            type="submit"
            class="px-6 py-2 rounded-lg bg-blue-600 text-white hover:bg-blue-700 font-medium"
          >
            Salvar
            <!-- Atualizar -->
          </button>
        </div>

      </form>

    </div>

  </div>