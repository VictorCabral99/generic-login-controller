<div class="max-w-7xl mx-auto px-6 py-8">

    <!-- Header -->
    <div class="flex items-center justify-between mb-6">
        <h1 class="text-2xl font-bold text-gray-800">Permissões</h1>

        <button class="bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-lg text-sm font-medium">
            + Nova Permissão
        </button>
    </div>

    <!-- Filtro -->
    <div class="bg-white p-4 rounded-lg shadow mb-6">
        <div class="flex flex-col md:flex-row gap-4">
            <input type="text" placeholder="Buscar permissão..."
                class="w-full md:w-1/3 border border-gray-300 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500" />

            <select
                class="w-full md:w-1/4 border border-gray-300 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500">
                <option>Todos os módulos</option>
                <option>Usuários</option>
                <option>Financeiro</option>
                <option>Relatórios</option>
            </select>
        </div>
    </div>

    <!-- Tabela -->
    <div class="bg-white rounded-lg shadow overflow-x-auto">
        <table class="min-w-full text-sm text-left">
            <thead class="bg-gray-50 border-b">
                <tr>
                    <th class="px-6 py-3 font-semibold text-gray-600">Permissão</th>
                    <th class="px-6 py-3 font-semibold text-gray-600">Módulo</th>
                    <th class="px-6 py-3 font-semibold text-gray-600">Descrição</th>
                    <th class="px-6 py-3 font-semibold text-gray-600">Status</th>
                    <th class="px-6 py-3 font-semibold text-gray-600 text-right">Ações</th>
                </tr>
            </thead>

            <tbody class="divide-y">
                <tr class="hover:bg-gray-50">
                    <td class="px-6 py-4 font-mono text-gray-800">user.create</td>
                    <td class="px-6 py-4 text-gray-600">Usuários</td>
                    <td class="px-6 py-4 text-gray-600">Criar novos usuários</td>
                    <td class="px-6 py-4">
                        <span class="bg-green-100 text-green-700 px-3 py-1 rounded-full text-xs font-semibold">
                            Ativa
                        </span>
                    </td>
                    <td class="px-6 py-4 text-right space-x-3">
                        <button class="text-blue-600 hover:underline">Editar</button>
                        <button class="text-red-600 hover:underline">Excluir</button>
                    </td>
                </tr>

                <tr class="hover:bg-gray-50">
                    <td class="px-6 py-4 font-mono text-gray-800">user.delete</td>
                    <td class="px-6 py-4 text-gray-600">Usuários</td>
                    <td class="px-6 py-4 text-gray-600">Excluir usuários</td>
                    <td class="px-6 py-4">
                        <span class="bg-yellow-100 text-yellow-700 px-3 py-1 rounded-full text-xs font-semibold">
                            Restrita
                        </span>
                    </td>
                    <td class="px-6 py-4 text-right space-x-3">
                        <button class="text-blue-600 hover:underline">Editar</button>
                        <button class="text-red-600 hover:underline">Excluir</button>
                    </td>
                </tr>

                <tr class="hover:bg-gray-50">
                    <td class="px-6 py-4 font-mono text-gray-800">report.view</td>
                    <td class="px-6 py-4 text-gray-600">Relatórios</td>
                    <td class="px-6 py-4 text-gray-600">Visualizar relatórios</td>
                    <td class="px-6 py-4">
                        <span class="bg-red-100 text-red-700 px-3 py-1 rounded-full text-xs font-semibold">
                            Inativa
                        </span>
                    </td>
                    <td class="px-6 py-4 text-right space-x-3">
                        <button class="text-blue-600 hover:underline">Editar</button>
                        <button class="text-red-600 hover:underline">Excluir</button>
                    </td>
                </tr>
            </tbody>
        </table>
    </div>

</div>