<div class="w-full max-w-md bg-white rounded-2xl shadow-lg p-8">
    
    <!-- Título -->
    <div class="text-center mb-8">
      <h1 class="text-2xl font-bold text-gray-800">Resetar Senha</h1>
      <p class="text-gray-500 text-sm mt-1">Digite sua nova senha abaixo</p>
    </div>

    <!-- Alerta de Erro -->
    <div id="erro" class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded-lg mb-5 hidden">
      <p id="mensagemErro"></p>
    </div>

    <!-- Alerta de Sucesso -->
    <div id="sucesso" class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded-lg mb-5 hidden">
      <p id="mensagemSucesso"></p>
    </div>

    <!-- Formulário -->
    <form id="formularioReset" class="space-y-5">

      <!-- Nova Senha -->
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">
          Nova Senha
        </label>
        <input
          id="novaSenha"
          type="password"
          placeholder="Digite sua nova senha"
          required
          class="w-full rounded-lg border border-gray-300 px-4 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent"
        />
      </div>

      <!-- Confirmar Senha -->
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">
          Confirmar Senha
        </label>
        <input
          id="confirmarSenha"
          type="password"
          placeholder="Confirme sua nova senha"
          required
          class="w-full rounded-lg border border-gray-300 px-4 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent"
        />
      </div>

      <!-- Botão -->
      <button
        type="submit"
        class="w-full bg-blue-600 text-white py-2 rounded-lg font-semibold hover:bg-blue-700 transition"
      >
        Resetar Senha
      </button>

      <!-- Link volta para login -->
      <div class="text-center mt-4">
        <a href="/login" class="text-blue-600 hover:underline text-sm">
          Voltar para login
        </a>
      </div>

    </form>

  </div>

  <script>
    // Pegar token da URL
    const urlParams = new URLSearchParams(window.location.search);
    const token = urlParams.get('token');

    // Se não houver token na URL, redirecionar para login
    if (!token) {
      alert('Token inválido! Solicite um novo reset de senha.');
      window.location.href = '/login';
    }

    // Capturar envio do formulário
    document.getElementById('formularioReset').addEventListener('submit', function(event) {
      event.preventDefault();

      const novaSenha = document.getElementById('novaSenha').value;
      const confirmarSenha = document.getElementById('confirmarSenha').value;

      // Validação 1: Verificar se as senhas coincidem
      if (novaSenha !== confirmarSenha) {
        mostrarErro('As senhas não coincidem!');
        return;
      }

      // Validação 2: Verificar se senha tem mínimo de 6 caracteres
      if (novaSenha.length < 6) {
        mostrarErro('A senha deve ter no mínimo 6 caracteres!');
        return;
      }

      // Fazer requisição POST para resetar a senha
      fetch('/api/auth/reset-password', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json'
        },
        body: JSON.stringify({ 
          token: token,
          novaSenha: novaSenha
        })
      })
      .then(response => response.json())
      .then(data => {
        // Se houve erro na resposta
        if (data.erro) {
          mostrarErro(data.erro);
          return;
        }

        // Se reset foi bem sucedido
        if (data.mensagem) {
          mostrarSucesso('Senha resetada com sucesso! Redirecionando para login...');
          
          // Redirecionar para login após 2 segundos
          setTimeout(() => {
            window.location.href = '/login';
          }, 2000);
        }
      })
      .catch(error => {
        console.error('Erro:', error);
        mostrarErro('Erro ao resetar senha! Tente novamente.');
      });
    });

    function mostrarErro(mensagem) {
      const erroDiv = document.getElementById('erro');
      const mensagemErro = document.getElementById('mensagemErro');
      mensagemErro.textContent = mensagem;
      erroDiv.classList.remove('hidden');

      // Desaparecer o erro após 5 segundos
      setTimeout(() => {
        erroDiv.classList.add('hidden');
      }, 5000);
    }

    function mostrarSucesso(mensagem) {
      const sucessoDiv = document.getElementById('sucesso');
      const mensagemSucesso = document.getElementById('mensagemSucesso');
      mensagemSucesso.textContent = mensagem;
      sucessoDiv.classList.remove('hidden');
    }
  </script>
