<div class="w-full max-w-md bg-white rounded-2xl shadow-lg p-8">
    
    <!-- Título -->
    <div class="text-center mb-8">
      <h1 class="text-2xl font-bold text-gray-800">Bem-vindo de volta</h1>
      <p class="text-gray-500 text-sm mt-1">Faça login para continuar</p>
    </div>

    <!-- Formulário -->
    <form class="space-y-5">

      <!-- Email -->
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">
          Email
        </label>
        <input
          type="email"
          placeholder="seu@email.com"
          class="w-full rounded-lg border border-gray-300 px-4 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent"
        />
      </div>

      <!-- Senha -->
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">
          Senha
        </label>
        <input
          type="password"
          placeholder="••••••••"
          class="w-full rounded-lg border border-gray-300 px-4 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent"
        />
      </div>

      <!-- Lembrar / Esqueci senha -->
      <div class="flex items-center justify-between text-sm">
        <label class="flex items-center gap-2 text-gray-600">
          <input type="checkbox" class="rounded border-gray-300" />
          Lembrar-me
        </label>
        <a href="/forgot-password" class="text-blue-600 hover:underline">
          Esqueci a senha
        </a>
      </div>

      <!-- Botão -->
      <button
        type="submit"
        class="w-full bg-blue-600 text-white py-2 rounded-lg font-semibold hover:bg-blue-700 transition"
      >
        Entrar
      </button>

    </form>
  </div>